# 数据库配置（默认 SQLite，零配置部署）
# SQLite（默认）: file:./data/claude_code_pilot.db
# MySQL: mysql://root:password@localhost:3306/claude_code_pilot
DATABASE_URL="file:./data/claude_code_pilot.db"

# JWT 密钥
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# 管理员密码
AUTH_PASSWORD="admin123"

# 服务端口
PORT=3000
SOCKET_PORT=3001

# CORS 允许的域名（多个用逗号分隔）
CORS_ORIGIN="http://localhost:3000"

# Nginx server_name（域名或 IP，deploy.sh 自动写入 Nginx 配置）
SERVER_NAME="your-domain.com"

# Shell 路径（可选，Windows 默认 cmd.exe，Unix 默认 /bin/zsh）
# SHELL_PATH="C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe"

# 是否将任务输出持久化到数据库（默认 true，输出较大时可设为 false 节省存储）
# SAVE_OUTPUT=false
